<!-- pages/index/index.wxml -->
<view class="container">

  <!-- 搜索框 -->
  <view class="search-area">
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="输入汉字，如：中国"
        placeholder-class="search-placeholder"
        bindinput="onInput"
        value="{{inputValue}}"
        maxlength="20"
      />
      <view class="search-clear" wx:if="{{inputValue.length > 0}}" bindtap="onClearInput">✕</view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{inputValue.length > 0}}">
    <view class="char-list" wx:if="{{chars.length > 0}}">
      <view
        wx:for="{{chars}}"
        wx:key="*this"
        class="char-card {{selectedChar === item ? 'char-card--active' : ''}}"
        bindtap="onSelectChar"
        data-char="{{item}}"
      >{{item}}</view>
    </view>
    <view class="empty-hint" wx:else>
      <text>请输入汉字</text>
    </view>
  </view>

  <!-- 默认状态：最近查询 -->
  <view wx:if="{{inputValue.length === 0 && recentChars.length > 0}}" class="section">
    <view class="section-header">
      <text class="section-title">最近查询</text>
      <text class="section-clear" bindtap="onClearRecent">清除</text>
    </view>
    <scroll-view scroll-x class="char-scroll" show-scrollbar="{{false}}">
      <view class="char-row">
        <view
          wx:for="{{recentChars}}"
          wx:key="*this"
          class="char-card {{selectedChar === item ? 'char-card--active' : ''}}"
          bindtap="onSelectChar"
          data-char="{{item}}"
        >{{item}}</view>
      </view>
    </scroll-view>
  </view>

  <!-- 动画区域 -->
  <view class="animation-area" wx:if="{{selectedChar}}">

    <!-- 主动画画布 -->
    <view class="canvas-wrapper">
      <hanzi-writer-view id="hanzi-writer" width="300" height="300" />
      <!-- 田字格 -->
      <view class="grid-overlay">
        <view class="grid-h"></view>
        <view class="grid-v"></view>
      </view>
      <view class="loading-mask" wx:if="{{loading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="error-mask" wx:if="{{errorMsg}}">
        <text class="error-text">{{errorMsg}}</text>
      </view>
    </view>

    <!-- 笔画分解：平铺换行，每格展示累积到第 n 笔的状态，当前笔红色 -->
    <view class="stroke-section" wx:if="{{strokeSteps.length > 0}}">
      <view class="stroke-grid">
        <view
          wx:for="{{strokeSteps}}"
          wx:key="n"
          class="stroke-card-outer"
        >
          <view class="stroke-mini-card">
            <!-- BG：轮廓 + 已完成笔画（深色） -->
            <hanzi-writer-view id="sw-bg-{{item.n}}" width="40" height="40" />
            <!-- RED：当前笔画（红色），绝对定位叠加 -->
            <view class="sw-red-layer">
              <hanzi-writer-view id="sw-red-{{item.n}}" width="40" height="40" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 重播 -->
    <view
      class="replay-btn {{animDone ? 'replay-btn--active' : ''}}"
      bindtap="onReplay"
    >▶ 重播</view>

  </view>

</view>
