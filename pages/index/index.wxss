/* pages/index/index.wxss */

/* ── 全局 ── */
.container {
  padding: 32rpx 24rpx 64rpx;
  min-height: 100vh;
}

/* ── 搜索框 ── */
.search-area {
  margin-bottom: 40rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 48rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.07);
}

.search-icon {
  font-size: 40rpx;
  color: #c9473b;
  margin-right: 12rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  color: #2c2c2c;
  background: transparent;
}

.search-placeholder {
  color: #ccc;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── 字卡（搜索结果，换行布局）── */
.char-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

/* ── 字卡（历史，横向滚动）── */
.char-scroll {
  width: 100%;
  white-space: nowrap;
}

.char-row {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

/* ── 字卡通用 ── */
.char-card {
  width: 96rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #2c2c2c;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 4rpx solid transparent;
  flex-shrink: 0;
}

.char-card--active {
  border-color: #c9473b;
  background: #fef5f4;
  color: #c9473b;
}

/* ── 分组区块 ── */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
}

.section-clear {
  font-size: 24rpx;
  color: #c9473b;
  opacity: 0.7;
}

/* ── 空状态 ── */
.empty-hint {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding-top: 80rpx;
}

/* ── 动画区域 ── */
.animation-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  margin-top: 8rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* ── 画布 ── */
.canvas-wrapper {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  border: 2rpx solid rgba(201, 71, 59, 0.12);
}

/* 田字格 */
.grid-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.grid-h {
  position: absolute;
  top: 50%;
  left: 4%;
  right: 4%;
  height: 1rpx;
  background: rgba(193, 154, 107, 0.25);
  transform: translateY(-50%);
}

.grid-v {
  position: absolute;
  left: 50%;
  top: 4%;
  bottom: 4%;
  width: 1rpx;
  background: rgba(193, 154, 107, 0.25);
  transform: translateX(-50%);
}

/* loading / error */
.loading-mask,
.error-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  z-index: 10;
}

.loading-text {
  font-size: 28rpx;
  color: #aaa;
}

.error-text {
  font-size: 28rpx;
  color: #c9473b;
}

/* ── 笔画分解（平铺换行）── */
.stroke-section {
  width: 100%;
  margin-top: 32rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  padding-top: 24rpx;
}

.stroke-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

/* 单个笔画卡片：BG + RED 两个 canvas 叠加，canvas 40×40px = 80rpx */
.stroke-mini-card {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.07);
  overflow: hidden;
  border: 1rpx solid rgba(201, 71, 59, 0.08);
}

/* 红色笔画层，绝对覆盖在 BG 上 */
.sw-red-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 80rpx;
  height: 80rpx;
  pointer-events: none;
}


/* ── 重播按钮 ── */
.replay-btn {
  margin-top: 36rpx;
  padding: 20rpx 72rpx;
  background: #ede8e0;
  color: #bbb;
  border-radius: 48rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

.replay-btn--active {
  background: #c9473b;
  color: #fff;
}
